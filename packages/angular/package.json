{
  "name": "@aleks-thunder/angular",
  "version": "5.0.0",
  "description": "Shared Angular lint and format configuration",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aleks-thunder/lint-and-formating-semantic-releases.git"
  },
  "main": "eslint.js",
  "exports": {
    ".": "./eslint.js",
    "./eslint": "./eslint.js",
    "./prettier": "./prettier.js"
  },
  "files": [
    "eslint.js",
    "prettier.js"
  ],
  "dependencies": {
    "@aleks-thunder/base": "*",
    "@eslint/js": "^9.0.0",
    "angular-eslint": "^20.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "eslint-plugin-unused-imports": "^4.0.0",
    "prettier-plugin-multiline-arrays": "^4.0.3",
    "typescript-eslint": "^8.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "release": {
    "extends": "../../.releaserc.json",
    "tagFormat": "angular-v${version}"
  }
}
